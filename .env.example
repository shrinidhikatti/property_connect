# ── Django ────────────────────────────────────────────────────────────────────
DJANGO_SETTINGS_MODULE=config.settings.prod
SECRET_KEY=change-me-to-a-50-char-random-string

# ── Database (PostgreSQL + PostGIS in prod) ────────────────────────────────────
DB_NAME=propconnect
DB_USER=propconnect
DB_PASSWORD=strong-db-password
DB_HOST=localhost
DB_PORT=5432

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://127.0.0.1:6379/0

# ── Hosts ─────────────────────────────────────────────────────────────────────
ALLOWED_HOSTS=belagaviproperty.com,www.belagaviproperty.com

# ── AWS S3 (document storage) ──────────────────────────────────────────────────
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_BUCKET_NAME=propconnect-documents
AWS_REGION=ap-south-1

# ── Cloudinary (property images) ──────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ── Razorpay ──────────────────────────────────────────────────────────────────
RAZORPAY_KEY_ID=rzp_live_xxxxxxxxxxxxxxxx
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

# ── Email (SendGrid via anymail) ───────────────────────────────────────────────
SENDGRID_API_KEY=

# ── WhatsApp Business API ─────────────────────────────────────────────────────
WHATSAPP_PHONE_ID=
WHATSAPP_ACCESS_TOKEN=

# ── Monitoring ────────────────────────────────────────────────────────────────
SENTRY_DSN=

# ── Frontend ──────────────────────────────────────────────────────────────────
# Used by Vite at build time
VITE_API_BASE_URL=https://belagaviproperty.com/api/v1
VITE_WS_URL=wss://belagaviproperty.com

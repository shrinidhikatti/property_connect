{
  "buildCommand": "cd frontend && npm ci --legacy-peer-deps && npm run build",
  "outputDirectory": "frontend/dist",
  "functions": {
    "api/index.py": {
      "maxDuration": 30
    }
  },
  "rewrites": [
    { "source": "/api/v1/:path*", "destination": "/api/index.py" },
    { "source": "/(.*)",           "destination": "/index.html" }
  ]
}
